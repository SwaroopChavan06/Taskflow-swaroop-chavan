# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=taskflow

# Constructed from the above by docker-compose; override if using an external DB.
DATABASE_URL=postgres://taskflow:changeme@db:5432/taskflow?sslmode=disable

# ── API ───────────────────────────────────────────────────────────────────────
PORT=4000

# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-secure-random-string-at-least-32-chars

JWT_EXPIRY_HOURS=24

APP_ENV=development

# ── Frontend (optional) ───────────────────────────────────────────────────────
# When running behind nginx (docker compose), the frontend proxies to /api.
# Override only if the frontend is served from a different origin.
# VITE_API_URL=http://localhost:4000
